{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["node"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"paths": {
			"@/lib/utils": ["./src/lib/cn.ts"],
			"@/types/icon": ["./src/lib/icon-handle.ts"]
		}
	},
	"include": ["src/**/*", "scripts/**/*.ts", "tsup.config.ts"],
	"exclude": ["node_modules", "dist", "scripts/**/*.mjs"]
}
