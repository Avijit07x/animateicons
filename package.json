{
	"name": "animateicons",
	"version": "0.1.0",
	"private": true,
	"packageManager": "pnpm@10.0.0",
	"scripts": {
		"format": "prettier --write .",
		"gen:icons-json": "tsx scripts/generate-icons-json.ts",
		"gen:registry": "tsx scripts/generate-registry.ts",
		"gen:icons": "pnpm run gen:icons-json && pnpm run gen:registry",
		"check:icons": "tsx scripts/check-duplicate-icons.ts",
		"check:registry": "tsx scripts/check-registry.ts",
		"check:all": "pnpm run format && pnpm run check:icons && pnpm run check:registry",
		"prebuild": "pnpm run gen:icons && pnpm run check:all",
		"dev": "pnpm run gen:icons && pnpm run check:all && next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "echo \"lint disabled\" && exit 0",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@mdx-js/loader": "^3.1.1",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.4",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@types/mdx": "^2.0.13",
		"@vercel/analytics": "^1.6.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"fuse.js": "^7.3.0",
		"lucide-react": "^0.564.0",
		"motion": "^12.38.0",
		"next": "^16.2.4",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"shiki": "^3.23.0",
		"swr": "^2.4.1",
		"tailwind-merge": "^3.5.0",
		"use-debounce": "^10.1.1"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"baseline-browser-mapping": "^2.10.24",
		"jsdom": "^26.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
