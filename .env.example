# Google Search Console verification (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Buy Me a Coffee — Personal Access Token
# Generate at https://developers.buymeacoffee.com/dashboard
# Used by /sponsors to fetch the supporter list. Server-only.
BMC_ACCESS_TOKEN=

# GitHub Sponsors — Personal Access Token (read:user scope is enough)
# Generate at https://github.com/settings/tokens
# Used by /sponsors to fetch the GitHub sponsor list. Server-only.
GITHUB_SPONSORS_TOKEN=
